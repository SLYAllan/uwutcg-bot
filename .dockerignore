# Secrets — ne JAMAIS mettre dans l'image (injecté au runtime via env_file)
.env
*.env
!.env.example

# Données / runtime (montées en volume)
data/
*.db
*.db-*
logs/
*.log

# Python local
.venv/
venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Playwright local (l'image officielle fournit les navigateurs)
ms-playwright/

# Git / docs / dev
.git/
.gitignore
docs/
tests/
scripts/
*.md
!README.md
