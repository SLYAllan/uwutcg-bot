# ============================================================================
#  UwUTCG Tracking Bot — modèle d'environnement. Copier en .env et remplir.
# ============================================================================

# ---- Discord ----
# BOT TOKEN (portail dev → onglet "Bot" → "Reset Token"). PAS le client secret.
DISCORD_TOKEN=MTxxxxxxxxxxxxxxxxxxxxxxxx.Gxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DISCORD_APP_ID=000000000000000000
DISCORD_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ID du serveur pour sync rapide des slash commands en dev (optionnel)
DISCORD_GUILD_ID=000000000000000000

# Salons par défaut (IDs numériques)
DEFAULT_TRACK_CHANNEL_ID=
DAILY_DIGEST_CHANNEL_ID=

# ---- eBay (API Browse — OAuth client credentials) ----
# https://developer.ebay.com/ → My Account → Application Keys (keyset PRODUCTION)
EBAY_APP_ID=YourApp-xxxx-PRD-xxxxxxxxx-xxxxxxxx
EBAY_DEV_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EBAY_CERT_ID=PRD-xxxxxxxxxxxx-xxxx-xxxx-xxxx-xxxx
EBAY_MARKETPLACE_ID=EBAY_FR
EBAY_ENV=PRODUCTION

# ---- Vinted ----
VINTED_DOMAIN=www.vinted.fr
VINTED_SESSION_COOKIE=

# ---- Divers ----
TIMEZONE=Europe/Paris
LOG_LEVEL=INFO
DB_PATH=data/bot.db
KNOWLEDGE_DIR=knowledge
PRICING_CONFIG=pricing.yaml
